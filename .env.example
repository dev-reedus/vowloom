# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# `.env` is git-ignored, so your real password never gets committed.
# deploy.sh loads it automatically; values you pass on the command line
# (e.g. `HOST_PORT=80 ./deploy.sh`) still take precedence.

# Public wedding identity shown on login, guest list, prints, footer, and gallery.
WEDDING_COUPLE_NAMES=Alex & Sam
WEDDING_YEAR=
DEFAULT_LANGUAGE=it

# Optional generic demo tables for a brand-new database. Leave disabled for a
# real deployment so the seating room starts empty.
SEED_EXAMPLE_TABLES=

# Login passwords. The password entered on the login screen determines the role.
# Both are REQUIRED for a public deployment and MUST be distinct.
COUPLE_PASSWORD=
ADMIN_PASSWORD=

# Legacy: AUTH_PASSWORD is still honored as the COUPLE_PASSWORD fallback if
# COUPLE_PASSWORD is unset (smooth migration). AUTH_USER is retired and ignored.
AUTH_PASSWORD=

# Retired as a login credential. Still read as legacy key material for guest-token
# encryption (TOKEN_SECRET || ADMIN_KEY), so existing guest links keep working.
# Prefer setting TOKEN_SECRET below for new deployments.
ADMIN_KEY=

# The server refuses to start unless COUPLE_PASSWORD and ADMIN_PASSWORD are set,
# non-guessable, and distinct. For local development without real secrets, set
# ALLOW_INSECURE_AUTH=1 to downgrade that hard failure to a warning AND relax the
# session cookie's Secure flag so it survives plain-HTTP dev.
ALLOW_INSECURE_AUTH=

# Guest links are encrypted at rest with this key. If unset, it is derived from
# ADMIN_KEY - meaning rotating ADMIN_KEY would invalidate existing links. Set a
# dedicated long random value to decouple the two and keep links valid across
# ADMIN_KEY changes. Changing TOKEN_SECRET itself invalidates existing links.
TOKEN_SECRET=

# Optional dedicated key for binding sessions to the current role passwords.
# If unset, TOKEN_SECRET is used (or legacy ADMIN_KEY as a final fallback).
SESSION_SECRET=

# Cloudflare R2 gallery storage.
# R2_ACCOUNT_ID is visible in the Cloudflare dashboard URL / account overview.
# R2 access keys are created from Cloudflare R2 > Manage R2 API tokens.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Optional public/custom URL for cacheable derivative images.
# Leave empty to serve derivative images through short-lived presigned URLs.
# Example: https://photos.example.com
R2_PUBLIC_BASE_URL=

# Gallery limits and image generation.
GALLERY_DOWNLOAD_URL_EXPIRES_SECONDS=300
GALLERY_DISPLAY_URL_EXPIRES_SECONDS=3600
GALLERY_TOKEN_DAILY_DOWNLOAD_LIMIT=200
GALLERY_DISPLAY_IMAGE_SIZE=2048
GALLERY_MONTHLY_BUDGET_USD=10

# Container / networking
APP_NAME=vowloom
HOST_PORT=8091

# Docker volume that holds the SQLite DB (defaults to <APP_NAME>-data).
# DATA_VOLUME=vowloom-data
